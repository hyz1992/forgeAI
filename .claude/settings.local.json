{
  "permissions": {
    "allow": [
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(node *)",
      "Bash(pnpm *)",
      "Bash(python *)",
      "Bash(git *)",
      "Bash(curl *)",
      "Bash(cd *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(mkdir *)",
      "Bash(rm *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(claude *)",
      "Read(*)",
      "Write(*)",
      "Edit(*)",
      "Skill(fi-init)",
      "Skill(fi-plan)",
      "Skill(fi-auto)",
      "Skill(fi-contract)",
      "Skill(fi-test)",
      "Skill(fi-implement)",
      "Skill(fi-fix)",
      "Skill(fi-review)",
      "Skill(fi-run)",
      "Skill(fi-video)",
      "Skill(fi-content)",
      "Skill(superpowers:brainstorming)",
      "Skill(superpowers:writing-plans)",
      "Skill(superpowers:test-driven-development)",
      "Skill(superpowers:systematic-debugging)",
      "Skill(superpowers:requesting-code-review)",
      "Skill(superpowers:verification-before-completion)",
      "Skill(superpowers:executing-plans)",
      "Skill(superpowers:using-git-worktrees)",
      "Skill(ui-ux-pro-max)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/post-tool-use.py \"{tool}\" \"{file_path}\""
          }
        ]
      }
    ]
  }
}
